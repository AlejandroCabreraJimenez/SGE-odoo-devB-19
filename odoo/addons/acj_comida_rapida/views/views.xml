<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Category Views -->
    <record model="ir.ui.view" id="acj_comida_rapida.category_tree">
      <field name="name">acj_comida_rapida.category.tree</field>
      <field name="model">acj_comida_rapida.category</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="description"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="acj_comida_rapida.category_form">
      <field name="name">acj_comida_rapida.category.form</field>
      <field name="model">acj_comida_rapida.category</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="description"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Ingredient Views -->
    <record model="ir.ui.view" id="acj_comida_rapida.ingredient_tree">
      <field name="name">acj_comida_rapida.ingredient.tree</field>
      <field name="model">acj_comida_rapida.ingredient</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="price"/>
          <field name="description"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="acj_comida_rapida.ingredient_form">
      <field name="name">acj_comida_rapida.ingredient.form</field>
      <field name="model">acj_comida_rapida.ingredient</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="price"/>
              <field name="description"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Product Views -->
    <record model="ir.ui.view" id="acj_comida_rapida.product_tree">
      <field name="name">acj_comida_rapida.product.tree</field>
      <field name="model">acj_comida_rapida.product</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="price"/>
          <field name="category_id"/>
          <field name="ingredient_count"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="acj_comida_rapida.product_kanban">
      <field name="name">acj_comida_rapida.product.kanban</field>
      <field name="model">acj_comida_rapida.product</field>
      <field name="arch" type="xml">
        <kanban>
          <field name="name"/>
          <field name="price"/>
          <field name="category_id"/>
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_card">
                <div class="oe_kanban_content">
                  <h4><field name="name"/></h4>
                  <p><field name="price"/> €</p>
                  <p><field name="category_id"/></p>
                  <p>Ingredientes: <field name="ingredient_count"/></p>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <record model="ir.ui.view" id="acj_comida_rapida.product_search">
      <field name="name">acj_comida_rapida.product.search</field>
      <field name="model">acj_comida_rapida.product</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="category_id"/>
          <group expand="0" string="Agrupar por">
            <filter name="group_by_category" string="Categoría" context="{'group_by': 'category_id'}"/>
          </group>
        </search>
      </field>
    </record>

    <record model="ir.ui.view" id="acj_comida_rapida.product_form">
      <field name="name">acj_comida_rapida.product.form</field>
      <field name="model">acj_comida_rapida.product</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="price"/>
              <field name="category_id"/>
              <field name="ingredient_count"/>
              <field name="description"/>
              <field name="image" widget="image"/>
            </group>
            <notebook>
              <page string="Ingredientes">
                <field name="ingredient_ids">
                  <tree>
                    <field name="name"/>
                    <field name="price"/>
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Order Line Views (for embedded) -->
    <record model="ir.ui.view" id="acj_comida_rapida.order_line_tree">
      <field name="name">acj_comida_rapida.order_line.tree</field>
      <field name="model">acj_comida_rapida.order_line</field>
      <field name="arch" type="xml">
        <tree editable="bottom">
          <field name="product_id"/>
          <field name="quantity"/>
          <field name="price_unit"/>
          <field name="price_subtotal"/>
        </tree>
      </field>
    </record>

    <!-- Order Views -->
    <record model="ir.ui.view" id="acj_comida_rapida.order_tree">
      <field name="name">acj_comida_rapida.order.tree</field>
      <field name="model">acj_comida_rapida.order</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="date"/>
          <field name="customer_id"/>
          <field name="total"/>
          <field name="state"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="acj_comida_rapida.order_form">
      <field name="name">acj_comida_rapida.order.form</field>
      <field name="model">acj_comida_rapida.order</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_confirm" string="Confirmar" type="object" states="draft" class="btn-primary"/>
            <button name="action_done" string="Completar" type="object" states="confirmed" class="btn-success"/>
            <button name="action_cancel" string="Cancelar" type="object" states="draft,confirmed" class="btn-danger"/>
            <button name="action_draft" string="Volver a Borrador" type="object" states="confirmed,cancelled" class="btn-secondary"/>
            <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
          </header>
          <sheet>
            <group>
              <field name="name"/>
              <field name="date"/>
              <field name="customer_id"/>
              <field name="total"/>
            </group>
            <notebook>
              <page string="Líneas de pedido">
                <field name="order_line_ids">
                  <tree>
                    <field name="product_id"/>
                    <field name="quantity"/>
                    <field name="price_unit"/>
                    <field name="price_subtotal"/>
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Actions -->
    <record model="ir.actions.act_window" id="acj_comida_rapida.category_action">
      <field name="name">Categorías</field>
      <field name="res_model">acj_comida_rapida.category</field>
      <field name="view_mode">tree,form</field>
    </record>

    <record model="ir.actions.act_window" id="acj_comida_rapida.ingredient_action">
      <field name="name">Ingredientes</field>
      <field name="res_model">acj_comida_rapida.ingredient</field>
      <field name="view_mode">tree,form</field>
    </record>

    <record model="ir.actions.act_window" id="acj_comida_rapida.product_action">
      <field name="name">Productos</field>
      <field name="res_model">acj_comida_rapida.product</field>
      <field name="view_mode">tree,kanban,form</field>
      <field name="search_view_id" ref="acj_comida_rapida.product_search"/>
    </record>

    <record model="ir.actions.act_window" id="acj_comida_rapida.order_action">
      <field name="name">Pedidos</field>
      <field name="res_model">acj_comida_rapida.order</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem name="Comida Rápida" id="acj_comida_rapida.menu_root"/>

    <menuitem name="Categorías" id="acj_comida_rapida.menu_category" parent="acj_comida_rapida.menu_root" action="acj_comida_rapida.category_action"/>
    <menuitem name="Ingredientes" id="acj_comida_rapida.menu_ingredient" parent="acj_comida_rapida.menu_root" action="acj_comida_rapida.ingredient_action"/>
    <menuitem name="Productos" id="acj_comida_rapida.menu_product" parent="acj_comida_rapida.menu_root" action="acj_comida_rapida.product_action"/>
    <menuitem name="Pedidos" id="acj_comida_rapida.menu_order" parent="acj_comida_rapida.menu_root" action="acj_comida_rapida.order_action"/>
  </data>
</odoo>
