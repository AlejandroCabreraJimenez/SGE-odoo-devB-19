<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Category Tree View -->
        <record id="view_acj_comida_category_tree" model="ir.ui.view">
            <field name="name">acj_comida.category.tree</field>
            <field name="model">acj_comida.category</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Category Form View -->
        <record id="view_acj_comida_category_form" model="ir.ui.view">
            <field name="name">acj_comida.category.form</field>
            <field name="model">acj_comida.category</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <field name="description"/>
                            <field name="image" widget="image" class="oe_avatar"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Category Action -->
        <record id="action_acj_comida_category" model="ir.actions.act_window">
            <field name="name">Categorías</field>
            <field name="res_model">acj_comida.category</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>