<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Order Search View -->
        <record id="view_acj_comida_order_search" model="ir.ui.view">
            <field name="name">acj_comida.order.search</field>
            <field name="model">acj_comida.order</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="state"/>
                    <filter name="draft" string="Borrador" domain="[('state', '=', 'draft')]"/>
                    <filter name="confirmed" string="Confirmado" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="done" string="Completado" domain="[('state', '=', 'done')]"/>
                    <filter name="cancelled" string="Cancelado" domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <filter name="high_value" string="Pedidos > 50€" domain="[('total', '>', 50)]"/>
                    <group expand="0" string="Agrupar por">
                        <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                        <filter name="group_customer" string="Cliente" context="{'group_by': 'customer_id'}"/>
                        <filter name="group_date" string="Fecha" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Order Kanban View -->
        <record id="view_acj_comida_order_kanban" model="ir.ui.view">
            <field name="name">acj_comida.order.kanban</field>
            <field name="model">acj_comida.order</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="total"/>
                    <field name="items_count"/>
                    <field name="state"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <strong><field name="name"/></strong>
                                    <div>
                                        <span class="badge badge-info"><field name="customer_id"/></span>
                                    </div>
                                    <div>Items: <field name="items_count"/></div>
                                    <div style="margin-top: 10px; font-weight: bold; color: green;">
                                        Total: <field name="total"/> €
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Order Tree View -->
        <record id="view_acj_comida_order_tree" model="ir.ui.view">
            <field name="name">acj_comida.order.tree</field>
            <field name="model">acj_comida.order</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="date"/>
                    <field name="items_count"/>
                    <field name="total"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Order Form View -->
        <record id="view_acj_comida_order_form" model="ir.ui.view">
            <field name="name">acj_comida.order.form</field>
            <field name="model">acj_comida.order</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" string="Confirmar" type="object" class="oe_highlight" states="draft"/>
                        <button name="action_done" string="Completed" type="object" class="oe_highlight" states="confirmed"/>
                        <button name="action_cancel" string="Cancelar" type="object" states="draft,confirmed"/>
                        <button name="action_draft" string="Back to Draft" type="object" states="cancelled"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="customer_id"/>
                                <field name="date"/>
                                <field name="estimated_date"/>
                            </group>
                            <group>
                                <field name="items_count"/>
                                <field name="total"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Líneas de Pedido">
                                <field name="order_line_ids">
                                    <tree editable="bottom">
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="price_unit"/>
                                        <field name="subtotal"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Order Action -->
        <record id="action_acj_comida_order" model="ir.actions.act_window">
            <field name="name">Pedidos</field>
            <field name="res_model">acj_comida.order</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_acj_comida_order_search"/>
        </record>
    </data>
</odoo>