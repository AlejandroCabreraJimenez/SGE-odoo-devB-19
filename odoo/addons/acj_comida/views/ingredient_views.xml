<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Ingredient Tree View -->
        <record id="view_acj_comida_ingredient_tree" model="ir.ui.view">
            <field name="name">acj_comida.ingredient.tree</field>
            <field name="model">acj_comida.ingredient</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="stock"/>
                    <field name="unit"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Ingredient Form View -->
        <record id="view_acj_comida_ingredient_form" model="ir.ui.view">
            <field name="name">acj_comida.ingredient.form</field>
            <field name="model">acj_comida.ingredient</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <field name="description"/>
                            <field name="stock"/>
                            <field name="unit"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Ingredient Action -->
        <record id="action_acj_comida_ingredient" model="ir.actions.act_window">
            <field name="name">Ingredientes</field>
            <field name="res_model">acj_comida.ingredient</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>