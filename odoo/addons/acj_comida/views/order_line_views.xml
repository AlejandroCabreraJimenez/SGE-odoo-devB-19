<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Order Line Tree View -->
        <record id="view_acj_comida_order_line_tree" model="ir.ui.view">
            <field name="name">acj_comida.order_line.tree</field>
            <field name="model">acj_comida.order_line</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="product_id"/>
                    <field name="quantity"/>
                    <field name="price_unit"/>
                    <field name="subtotal"/>
                </tree>
            </field>
        </record>

        <!-- Order Line Form View -->
        <record id="view_acj_comida_order_line_form" model="ir.ui.view">
            <field name="name">acj_comida.order_line.form</field>
            <field name="model">acj_comida.order_line</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="price_unit"/>
                        <field name="subtotal"/>
                    </group>
                </form>
            </field>
        </record>
    </data>
</odoo>